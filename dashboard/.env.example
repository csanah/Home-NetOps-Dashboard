# Dashboard Configuration
DASHBOARD_PIN=           # Required — PIN code for web login
DASHBOARD_PORT=9000      # Web server port (default: 9000)
DASHBOARD_SECRET=        # Flask session secret (auto-generated if empty)

# Card Visibility (true/false)
SHOW_UDM=false
SHOW_PROXMOX=false
SHOW_HA=false
SHOW_NAS=false
SHOW_MQTT=false
SHOW_MEDIA_CENTER=false
SHOW_FIREWALL=false
SHOW_DOWNLOADS=false

# UDM Pro
UDM_HOST=192.168.2.1
UDM_API_KEY=             # X-API-KEY for UniFi API
UDM_SSH_USER=root
UDM_SSH_PASS=            # SSH password (keyboard-interactive auth)

# Proxmox
PROXMOX_HOST=192.168.2.150
PROXMOX_PORT=8006
PROXMOX_TOKEN=           # PVEAPIToken (format: user@realm!tokenid=secret)
PROXMOX_NODE=            # Node name (e.g., maddown)
PROXMOX_SSH_USER=root
PROXMOX_SSH_PASS=

# Home Assistant
HA_HOST=192.168.2.93
HA_PORT=8123
HA_TOKEN=                # Long-lived access token

# Synology NAS
NAS_HOST=192.168.2.216
NAS_SSH_USER=
NAS_SSH_PASS=            # SSH password (keyboard-interactive auth)

# Bike Computer
BIKE_HOST=192.168.2.11
BIKE_SSH_USER=Claude
BIKE_SSH_PASS=

# Media Center VM
MEDIA_HOST=192.168.2.171
MEDIA_SSH_USER=Claude
MEDIA_SSH_PASS=

# Media Services (optional)
SABNZBD_PORT=8080
SABNZBD_API_KEY=
SONARR_PORT=8989
SONARR_API_KEY=
RADARR_PORT=7878
RADARR_API_KEY=
PROWLARR_PORT=9696
PROWLARR_API_KEY=

# Plex (optional)
PLEX_ENABLED=false
PLEX_HOST=
PLEX_PORT=32400
PLEX_TOKEN=

# Overseerr (optional)
OVERSEERR_ENABLED=false
OVERSEERR_HOST=192.168.2.216
OVERSEERR_PORT=5055
OVERSEERR_API_KEY=

# Claude Chat
CLAUDE_CHAT_ENABLED=false

# Display Names (optional overrides)
NAME_UDM=UDM Pro
NAME_PROXMOX=Proxmox
NAME_HA=Home Assistant
NAME_NAS=Synology NAS
NAME_MQTT=MQTT Broker
NAME_MEDIA_CENTER=Media Center
NAME_FIREWALL=Firewall
NAME_CHAT=Claude Chat
NAME_DOWNLOADS=Downloads
