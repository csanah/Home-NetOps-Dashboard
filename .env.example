# ── Dashboard ──
DASHBOARD_PIN=
DASHBOARD_PORT=7000

# ── UDM Pro ──
NAME_UDM=UDM Pro
UDM_HOST=your_udm_ip
UDM_API_KEY=your_udm_api_key
UDM_SSH_USER=root
UDM_SSH_PASS=your_udm_ssh_password

# ── Proxmox ──
NAME_PROXMOX=Proxmox
PROXMOX_HOST=your_proxmox_ip
PROXMOX_PORT=8006
PROXMOX_TOKEN=user@pam!tokenid=token-value
PROXMOX_NODE=your_node_name
PROXMOX_SSH_USER=root
PROXMOX_SSH_PASS=your_proxmox_ssh_password

# ── Home Assistant ──
NAME_HA=Home Assistant
HA_HOST=your_ha_ip
HA_PORT=8123
HA_TOKEN=your_long_lived_access_token

# ── MQTT ──
NAME_MQTT=MQTT Broker

# ── Synology NAS ──
NAME_NAS=Synology NAS
NAS_HOST=your_nas_ip
NAS_SSH_USER=your_nas_user
NAS_SSH_PASS=your_nas_ssh_password

# ── Bike Computer ──
NAME_BIKE=Bike Computer
BIKE_HOST=your_bike_ip
BIKE_SSH_USER=your_bike_user
BIKE_SSH_PASS=your_bike_ssh_password

# ── Media Center ──
NAME_MEDIA_CENTER=Media Center
MEDIA_HOST=your_media_center_ip
MEDIA_SSH_USER=your_media_user
MEDIA_SSH_PASS=your_media_ssh_password

# ── Downloads (SABnzbd / Sonarr / Radarr / Prowlarr) ──
SHOW_DOWNLOADS=true
NAME_DOWNLOADS=Downloads
SABNZBD_PORT=8080
SABNZBD_API_KEY=your_sabnzbd_api_key
SONARR_PORT=8989
SONARR_API_KEY=your_sonarr_api_key
RADARR_PORT=7878
RADARR_API_KEY=your_radarr_api_key
PROWLARR_PORT=9696
PROWLARR_API_KEY=your_prowlarr_api_key

# ── Firewall ──
SHOW_FIREWALL=true
NAME_FIREWALL=Firewall

# ── Claude Chat ──
CLAUDE_CHAT_ENABLED=true
NAME_CHAT=Claude Chat

# ── Card Visibility ──
SHOW_MEDIA_CENTER=true
SHOW_UDM=true
SHOW_PROXMOX=true
SHOW_HA=true
SHOW_NAS=true
SHOW_MQTT=true

# ── Plex ──
PLEX_ENABLED=false
NAME_PLEX=Plex
PLEX_HOST=your_plex_ip
PLEX_PORT=32400
PLEX_TOKEN=your_plex_token

# ── Overseerr ──
OVERSEERR_ENABLED=false
NAME_OVERSEERR=Overseerr
OVERSEERR_HOST=your_overseerr_ip
OVERSEERR_PORT=5055
OVERSEERR_API_KEY=your_overseerr_api_key
